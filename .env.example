# ============================================================
# CULTIVAI — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# Never commit .env to the repository.
# ============================================================

# Anthropic — improvement generator
ANTHROPIC_API_KEY=sk-ant-...

# GitHub — PR creation
GITHUB_TOKEN=ghp_...                   # classic PAT, repo scope
GITHUB_APP_ID=                         # Phase 3 — GitHub App
GITHUB_APP_PRIVATE_KEY=                # Phase 3 — GitHub App private key (PEM)

# Google Search Console
# Full service account JSON as a single minified string
GSC_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GSC_SUBJECT_EMAIL=your-gsc-account@gmail.com

# SerpAPI — SERP monitoring (serpapi.com)
SERPAPI_KEY=

# Firecrawl — competitor crawling (firecrawl.dev)
FIRECRAWL_API_KEY=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=              # obtained via OAuth
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Meta Ads
META_ACCESS_TOKEN=                     # long-lived page access token (60-day expiry)
META_APP_ID=
META_APP_SECRET=

# Microsoft Advertising (Bing)
BING_CLIENT_ID=
BING_CLIENT_SECRET=
BING_REFRESH_TOKEN=                    # obtained via OAuth
BING_DEVELOPER_TOKEN=

# Cultivai dashboard (Phase 2)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SENDGRID_API_KEY=
